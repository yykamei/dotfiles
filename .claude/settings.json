{
  "permissions": {
    "additionalDirectories": ["~/.config/opencode"],
    "ask": [
      "Bash(git*commit*)"
    ],
    "allow": [
      "Bash(cd:*)",
      "Bash(xargs:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(head:*)",
      "Bash(rm:*)",
      "Bash(git:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(tee:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run:*)",
      "Read(~/.config/opencode/**)",
      "Read(~/.plannotator/**)",
      "Read(~/.claude/**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "Write(//tmp/**)",
      "Write(//private/tmp/**)"
    ]
  }
}
