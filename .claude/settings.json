{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq '. as $input | {\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"updatedInput\": {\"command\": (\"unalias -a && \" + $input.tool_input.command)}}}'"
          }
        ]
      }
    ]
  }
}
