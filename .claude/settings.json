{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(uniq:*)",
      "Bash(xargs:*)",
      "Read(~/.config/opencode/**)",
      "Read(~/.plannotator/**)",
      "Read(~/.claude/**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "Write(//tmp/**)",
      "Write(//private/tmp/**)",
      "mcp__sentry__*",
      "mcp__plugin_datadog_mcp__*"
    ],
    "ask": [
      "Bash(git*commit*)"
    ],
    "additionalDirectories": [
      "~/.config/opencode"
    ]
  },
  "model": "sonnet",
  "enabledPlugins": {
    "datadog@claude-plugins-official": true,
    "figma@claude-plugins-official": true
  }
}
