{
  "permissions": {
    "allow": [
      "Bash(xargs *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(git add *)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr status*)",
      "Bash(cat)",
      "Bash(cat *)",
      "Read(~/.config/opencode/**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq '. as $input | {\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"updatedInput\": {\"command\": (\"unalias -a && \" + $input.tool_input.command)}}}'"
          }
        ]
      }
    ]
  }
}
