{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest"
  ],
  "autoupdate": false,
  "model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "~/.config/opencode/AGENTS.md",
    "~/.config/opencode/rules/*.md"
  ],
  "permission": {
    "read": {
      "*": "allow"
    },
    "external_directory": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow",
      "~/.rbenv/versions/**": "allow",
      "~/.cache/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "edit": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow",
      "~/.rbenv/versions/**": "deny",
      "~/.cache/**": "allow"
    },
    "bash": {
      "git commit": "ask",
      "git commit *": "ask",
      "git -C * commit": "ask",
      "git -C * commit *": "ask"
    }
  }
}
